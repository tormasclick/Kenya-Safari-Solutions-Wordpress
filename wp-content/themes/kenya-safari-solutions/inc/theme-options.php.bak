                    <td>
                        <input type="text" name="kenya_cta_title" value="<?php echo esc_attr(get_option('kenya_cta_title', 'Ready for your Kenya adventure?')); ?>" class="regular-text" />
                        <p class="description">The text before the gradient highlight</p>
                    </td>
                </tr>
                <tr>
                    <th scope="row"><?php echo esc_html__('Gradient Highlight Text', 'kenya-safari'); ?></th>
                    <td>
                        <input type="text" name="kenya_cta_gradient_text" value="<?php echo esc_attr(get_option('kenya_cta_gradient_text', 'Kenya adventure?')); ?>" class="regular-text" />
                        <p class="description">This text will have the gold gradient (include punctuation like ? or !)</p>
                    </td>
                </tr>
                <tr>
                    <th scope="row"><?php echo esc_html__('Description', 'kenya-safari'); ?></th>
                    <td>
                        <textarea name="kenya_cta_description" rows="3" class="large-text"><?php echo esc_textarea(get_option('kenya_cta_description', 'We\'ll design it around you. Reply in minutes — book in days.')); ?></textarea>
                    </td>
                </tr>
                <tr>
                    <th scope="row"><?php echo esc_html__('Button 1 Text', 'kenya-safari'); ?></th>
                    <td>
                        <input type="text" name="kenya_cta_btn1_text" value="<?php echo esc_attr(get_option('kenya_cta_btn1_text', 'Plan My Safari')); ?>" class="regular-text" />
                    </td>
                </tr>
                <tr>
                    <th scope="row"><?php echo esc_html__('Button 1 URL', 'kenya-safari'); ?></th>
                    <td>
                        <input type="text" name="kenya_cta_btn1_url" value="<?php echo esc_attr(get_option('kenya_cta_btn1_url', '#destinations')); ?>" class="regular-text" />
                        <p class="description">You can use # for anchor links or full URLs like https://example.com</p>
                    </td>
                </tr>
                <tr>
                    <th scope="row"><?php echo esc_html__('Button 2 Text', 'kenya-safari'); ?></th>
                    <td>
                        <input type="text" name="kenya_cta_btn2_text" value="<?php echo esc_attr(get_option('kenya_cta_btn2_text', 'Chat on WhatsApp')); ?>" class="regular-text" />
                    </td>
                </tr>
                <tr>
                    <th scope="row"><?php echo esc_html__('Background Color', 'kenya-safari'); ?></th>
                    <td>
                        <input type="color" name="kenya_cta_bg_color" value="<?php echo esc_attr(get_option('kenya_cta_bg_color', '#2a1f18')); ?>" />
                    </td>
                </tr>
                <tr>
                    <th scope="row"><?php echo esc_html__('Background Image', 'kenya-safari'); ?></th>
                    <td>
                        <div class="cta-image-upload">
                            <input type="hidden" name="kenya_cta_bg_image" id="kenya_cta_bg_image" value="<?php echo esc_attr(get_option('kenya_cta_bg_image', '')); ?>" />
                            <div id="cta-image-preview" style="margin-bottom: 10px;">
                                <?php 
                                $bg_image = get_option('kenya_cta_bg_image', '');
                                if ($bg_image): 
                                ?>
                                    <img src="<?php echo esc_url($bg_image); ?>" style="max-width: 300px; height: auto; border: 1px solid #ddd; padding: 5px;" />
                                <?php endif; ?>
                            </div>
                            <button type="button" class="button" id="upload-cta-image">Upload Image</button>
                            <button type="button" class="button" id="remove-cta-image" style="display: <?php echo $bg_image ? 'inline-block' : 'none'; ?>;">Remove Image</button>
                            <p class="description">Recommended size: 1920x1080px. Image will have 20% opacity overlay.</p>
