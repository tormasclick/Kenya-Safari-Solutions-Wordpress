<?php
/**
 * Theme Options Page for CTA Section
 */

// Add admin menu
function kenya_safari_admin_menu() {
    add_theme_page(
        'CTA Settings',
        'CTA Settings',
        'manage_options',
        'kenya-safari-cta',
        'kenya_safari_cta_page'
    );
}
add_action('admin_menu', 'kenya_safari_admin_menu');

// Register settings
function kenya_safari_register_settings() {
    register_setting('kenya_safari_cta_settings', 'kenya_cta_badge');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_title');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_gradient_text');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_description');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_btn1_text');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_btn1_url');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_btn2_text');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_bg_color');
    register_setting('kenya_safari_cta_settings', 'kenya_cta_bg_image');
}
add_action('admin_init', 'kenya_safari_register_settings');

// Enqueue media uploader script
function kenya_safari_admin_scripts($hook) {
    if ($hook != 'appearance_page_kenya-safari-cta') {
        return;
    }
    wp_enqueue_media();
    wp_enqueue_script('kenya-admin-upload', get_template_directory_uri() . '/assets/js/admin-upload.js', array('jquery'), '1.0', true);
}
add_action('admin_enqueue_scripts', 'kenya_safari_admin_scripts');

// CTA Settings Page
function kenya_safari_cta_page() {
    ?>
    <div class="wrap">
        <h1><?php echo esc_html__('CTA Section Settings', 'kenya-safari'); ?></h1>
        <form method="post" action="options.php">
            <?php settings_fields('kenya_safari_cta_settings'); ?>
            <?php do_settings_sections('kenya_safari_cta_settings'); ?>
            
            <table class="form-table">
                <tr>
                    <th scope="row"><?php echo esc_html__('Badge Text', 'kenya-safari'); ?></th>
                    <td>
                        <input type="text" name="kenya_cta_badge" value="<?php echo esc_attr(get_option('kenya_cta_badge', 'Ready when you are')); ?>" class="regular-text" />
