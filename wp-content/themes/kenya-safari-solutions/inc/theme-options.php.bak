}

// Custom sanitizer for URL field that allows #
function kenya_safari_sanitize_url_with_hash($input) {
    // Allow # for anchor links
    if ($input === '#' || strpos($input, '#') === 0) {
        return $input;
    }
    // Otherwise sanitize as URL
    return esc_url_raw($input);
}

// Add Footer Name setting
register_setting('kenya_safari_cta_settings', 'kenya_footer_name');
add_settings_field(
    'kenya_footer_name',
    'Site Name',
    'kenya_footer_name_callback',
    'kenya-safari-cta',
    'kenya_footer_section'
);

function kenya_footer_name_callback() {
    $name = get_option('kenya_footer_name', 'Kenya Safari Solutions');
    echo '<input type="text" name="kenya_footer_name" value="' . esc_attr($name) . '" class="regular-text" />';
}
